3. Approach
--------------

class Solution {
public:
    vector<int> productExceptSelf(vector<int>& nums) {
        int n = nums.size();

        vector<int> result(n);
        result[0] = 1;

        for(int i = 1; i < n; i++) {
            result[i] = result[i-1] * nums[i-1];
        }

        int right_prodcut = 1;
        for(int i = n-1; i >= 0; i--) {
            result[i] *= right_prodcut;
            right_prodcut *= nums[i];
        }

        return result;
    }
};		
