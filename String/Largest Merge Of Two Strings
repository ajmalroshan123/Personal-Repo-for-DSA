public:
    string largestMerge(string word1, string word2) {
        if(word1.empty()) return word2;
        if(word2.empty()) return word1;
       if(word1[0] > word2[0]){
        return word1[0] + largestMerge(word1.substr(1),word2);
       }else if(word2[0] > word1[0]){
        return word2[0] + largestMerge(word1,word2.substr(1));
       }else{
        string op1 = word1[0] + largestMerge(word1.substr(1),word2);;
        string op2 =  word2[0] + largestMerge(word1,word2.substr(1));
        return max(op1,op2);
       }
        
    }
