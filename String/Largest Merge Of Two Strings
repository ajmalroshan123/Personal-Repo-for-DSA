class Solution {
public:
    string largestMerge(string word1, string word2) {
        int n = word1.size();
        int m = word2.size();
        int i = 0, j = 0;
        string ans = "";
        while(i < n && j < m) {
            if(word1.substr(i) > word2.substr(j)){
                ans+=word1[i++];
            }else{
                ans+=word2[j++];
